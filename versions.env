# System Dependencies (minimum versions)
OPENCV_MIN_VERSION=4.6.0
GLOG_MIN_VERSION=0.6.0
CMAKE_MIN_VERSION=3.20

# Sibling repository refs (optional pin for reproducible builds).
# Leave commented on develop/master to let CMake auto-derive (develop or master)
# from the current branch / VERSION. Set them to matching sibling tags on a
# release tag so checking out that tag rebuilds against the exact same sibling
# code, even after master moves on. Precedence: cmake -D > versions.env > derived.
# NEURIPLO_VERSION=v0.2.3
# VIDEOCAPTURE_VERSION=v0.2.3
# VISION_CORE_VERSION=v0.2.3
